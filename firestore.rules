rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ─── Users collection ────────────────────────────────────────────────────
    match /users/{uid} {
      // Owner reads own doc; admin reads any doc
      allow get: if isOwner(uid) || isAdmin();

      // Any signed-in user can LIST (query) users — needed for referral code lookup
      allow list: if isSignedIn();

      // User creates their own doc on first sign-in.
      // isAdmin cannot be set by the user.
      // balance is allowed up to ₹100 on create (referee signup bonus).
      allow create: if isOwner(uid)
        && !('isAdmin' in request.resource.data)
        && (!('balance' in request.resource.data) || request.resource.data.balance <= 100);

      // FULL update: only admins
      allow update: if isAdmin()
        // RESTRICTED update: owner may ONLY change the `balance` field.
        || (isOwner(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance']))
        // Referee can credit referrer's balance+referralCount immediately on signup,
        // provided a pending referral doc (keyed by referee UID) exists pointing to this user.
        || (isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance', 'referralCount'])
          && get(/databases/$(database)/documents/referrals/$(request.auth.uid)).data.referrerUid == uid
          && get(/databases/$(database)/documents/referrals/$(request.auth.uid)).data.status == 'pending');
    }

    // ─── Placed Bets collection ──────────────────────────────────────────────
    match /placedBets/{uid}/bets/{betId} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && request.resource.data.status == 'pending'
        && request.resource.data.uid == request.auth.uid;

      allow update: if isAdmin()
        || (isOwner(uid)
          && resource.data.status == 'pending'
          && request.resource.data.status in ['won', 'lost']
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));

      allow delete: if false;
    }

    // ─── Deposits collection ─────────────────────────────────────────────────
    match /deposits/{depositId} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdmin());

      allow create: if isSignedIn()
        && request.resource.data.status == 'pending'
        && request.resource.data.uid == request.auth.uid;

      allow update: if isAdmin();
      allow delete: if false;
    }

    // ─── Referrals collection ────────────────────────────────────────────────
    // Doc ID = refereeUid (ensures one referral per user, enables rule-based lookups).
    match /referrals/{referralId} {
      allow read: if isSignedIn() && (
        resource.data.referrerUid == request.auth.uid ||
        resource.data.refereeUid  == request.auth.uid ||
        isAdmin()
      );

      // Referee creates OR admin creates
      allow create: if isSignedIn()
        && request.resource.data.status == 'pending'
        && request.resource.data.refereeUid == request.auth.uid;

      // Referee can mark their own referral as 'rewarded' (after crediting referrer)
      // Admin can update anything
      allow update: if isAdmin()
        || (isSignedIn()
          && resource.data.refereeUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));

      allow delete: if false;
    }

    // ─── Global placed bets (`collectionGroup('bets')` access for Admin) ───
    match /{path=**}/bets/{betId} {
      allow read, update: if isAdmin();
    }

    // ─── Everything else ─────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
